# ── Slack (required) ──
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_USER_TOKEN=xoxp-your-user-token

# ── Base URL (required in production) ──
# This is the public URL of your deployed bot.
# All other URLs (OAuth, focus timer) are derived from this.
# Local dev: leave empty (defaults to http://localhost:8080)
# Production: set to your Render URL
BASE_URL=https://oloidbot.onrender.com

# ── OAuth (optional override — auto-derived from BASE_URL) ──
# Only set this if your OAuth callback path is different from /oauth/callback
# OAUTH_REDIRECT_URI=https://oloidbot.onrender.com/oauth/callback
OAUTH_SERVER_PORT=8080

# ── Encryption key ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank for local dev (auto-generated and saved to data/encryption.key)
# In production: set this so your encrypted data survives redeployments
FERNET_KEY=

# ── Data directory ──
# Set to /opt/render/data on Render (persistent disk mount)
# Leave blank for local dev (uses ./data/)
DATA_DIR=/opt/render/data

# ── Ollama only (ignore if not using local LLM) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── Email polling interval in minutes ──
POLL_INTERVAL_MINUTES=5
