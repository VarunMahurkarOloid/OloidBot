# ── Slack (required) ──
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_USER_TOKEN=xoxp-your-user-token

# ── OAuth callback ──
# Local dev:
OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback
# Production (Render):
# OAUTH_REDIRECT_URI=https://oloidbot.onrender.com/oauth/callback
OAUTH_SERVER_PORT=8080

# ── Encryption key (production) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank for local dev (auto-generated and stored in data/encryption.key)
FERNET_KEY=

# ── Data directory (production) ──
# Set to /opt/render/data on Render (persistent disk mount)
# Leave blank for local dev (uses ./data/)
DATA_DIR=

# ── Ollama only (ignore if not using local LLM) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── Email polling interval in minutes ──
POLL_INTERVAL_MINUTES=5
